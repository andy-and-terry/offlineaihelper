# Ollama server base URL
OLLAMA_BASE_URL=http://localhost:11434

# Path to the moderation policy JSON file
MODERATION_POLICY_PATH=config/moderation.policy.json

# Path to the models routing config JSON file
MODELS_CONFIG_PATH=config/models.json

# When true, errors and unavailability in the moderation pipeline block the request
MODERATION_STRICT_MODE=true

# Seconds before an Ollama HTTP request times out
OLLAMA_TIMEOUT_SECONDS=30

# Number of retries on timeout or 5xx before raising OllamaUnavailableError
OLLAMA_MODERATION_RETRIES=2
